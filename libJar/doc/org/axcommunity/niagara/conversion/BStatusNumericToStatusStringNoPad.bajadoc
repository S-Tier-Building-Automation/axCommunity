<method name='setIntegerDigits' public='true'>
<parameter name='v' class='int'/>
<return class='void'/>
<description>Set the &lt;code&gt;integerDigits&lt;/code&gt; property.</description>
</method>

<!-- public int getDecimalDigits() -->
<method name='getDecimalDigits' public='true'>
<return class='int'/>
<description>Get the &lt;code&gt;decimalDigits&lt;/code&gt; property.
 </description>
<tag name='see'>com.tridium.kitControl.conversion.BStatusNumericToStatusString#decimalDigits</tag>
</method>

<!-- public void setDecimalDigits(int v) -->
<method name='setDecimalDigits' public='true'>
<parameter name='v' class='int'/>
<return class='void'/>
