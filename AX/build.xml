<!-- Module Build File -->

<module
	name			= "axCommunity"
	bajaVersion		= "0"
	preferredSymbol	= "axc"
	description		= "AX Community Objects"
	vendor			= "org.axcommunity"
	vendorVersion	= "17.02.28.01"
	edition			= "j2se-headless"
	>

	<!-- Dependencies -->
	<dependency name="baja" />
	<dependency name="control" />
	<dependency name="driver" />
	<dependency name="platform" />
	<dependency name="fox" />
	<dependency name="niagaraDriver" /> 
	<dependency name="bql" /> 
	<dependency name="workbench" /> 
	<dependency name="bajaui" /> 
	<dependency name="alarm" /> 
	<dependency name="history" /> 
	<dependency name="gx" /> 
	<dependency name="kitControl" />
	<dependency name="kitPx" />
	<dependency name="converters" />

	<!-- Packages -->
	<package name="org.axcommunity.niagara.conversion"	doc="true" />
	<package name="org.axcommunity.niagara.math"		doc="true" />
	<package name="org.axcommunity.niagara.logic"		doc="true" />
	<package name="org.axcommunity.niagara.bql"			doc="true" />
	<package name="org.axcommunity.niagara.system"		doc="true" />
	<package name="org.axcommunity.niagara.web"			doc="true" />
	<package name="org.axcommunity.niagara.string"		doc="true" />
	<package name="org.axcommunity.niagara.widgets"		doc="true" />
	<package name="org.axcommunity.niagara.time"		doc="true"/>
	<package name="org.axcommunity.niagara.extensions"	doc="true"/>
	<package name="org.axcommunity.niagara.hvac"		doc="true"/>
	<package name="org.axcommunity.niagara.views"		doc="true"/>
	<package name="org.axcommunity.niagara.weather"		doc="true"/>

	<resources name="doc/*.*" install="doc" />
	<resources name="org/axcommunity/niagara/graphics/*.*"/>

</module>
